{
  "name": "stohr",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "libs/atlas/packages/*"
  ],
  "scripts": {
    "dev": "bun src/dev.ts",
    "api": "bun --hot src/server.ts",
    "web": "bun --hot src/web/serve.ts",
    "test": "bun test --concurrency=1 tests/",
    "lint": "bunx biome lint packages/",
    "format": "bunx biome format packages/",
    "check": "bunx biome check packages/",
    "lint:fix": "bunx biome lint --write packages/",
    "format:fix": "bunx biome format --write packages/",
    "check:fix": "bunx biome check --write packages/",
    "tidy": "bun run format:fix && bun run lint:fix"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/bun": "latest"
  },
  "dependencies": {
    "@atlas/auth": "workspace:*",
    "@atlas/cli": "workspace:*",
    "@atlas/config": "workspace:*",
    "@atlas/db": "workspace:*",
    "@atlas/migrate": "workspace:*",
    "@atlas/server": "workspace:*",
    "@atlas/storage": "workspace:*",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@types/qrcode": "^1.5.6",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^19",
    "react-dom": "^19",
    "sharp": "^0.34.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
