PORT=3000
WEB_PORT=3001
API_URL=http://localhost:3000
SECRET=change-me-in-production
DATABASE_URL=postgres://postgres:postgres@localhost:5432/stohr
S3_ENDPOINT=http://localhost:4000
S3_BUCKET=stohr
S3_REGION=us-east-1
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin

# Public URL where the SPA is served. Used to build links in outgoing
# emails (password reset, invites). Must match what users see in their
# browser. Defaults to http://localhost:3001 for local dev.
APP_URL=http://localhost:3001

# Email — Resend (https://resend.com).
# Leave RESEND_API_KEY empty in development; emails will be printed to
# the API console instead of sent. Once set, emails go out for real.
# RESEND_FROM must be a verified sender on your Resend account, or use
# "Stohr <onboarding@resend.dev>" while you're testing.
RESEND_API_KEY=
RESEND_FROM=Stohr <onboarding@resend.dev>

# Passkeys (WebAuthn). RP_ID is the domain credentials are bound to —
# no port, no protocol. RP_ORIGIN is the full URL the SPA is served
# from. Credentials created on one RP_ID can't be used against another;
# a passkey created on localhost won't work on stohr.io. Set both for
# production.
RP_ID=localhost
RP_NAME=Stohr
RP_ORIGIN=http://localhost:3001

# Hard cap on a single request body, in bytes. Bun buffers the body
# before the handler runs, AND @atlas/storage further buffers it in
# memory to compute the SigV4 payload hash, so this is effectively a
# RAM ceiling per concurrent upload. Default: 1 GiB.
MAX_UPLOAD_BYTES=1073741824
